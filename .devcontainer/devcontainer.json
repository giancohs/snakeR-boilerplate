// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/rocker-org/devcontainer-templates/tree/main/src/r-ver
{
	// UI name (Cursor/VS Code) and container name = repo/folder name. Uses workspace folder when you "Open Folder" then "Reopen in Container". If you use "Clone in Container" and see a random name, set both to your repo name explicitly.
	"name": "${localWorkspaceFolderBasename}",
	// Base image; actual Ubuntu/R/Python versions are written to docs-and-references/installed-versions.md by install-dev-tools.sh
	"image": "ghcr.io/rocker-org/devcontainer/tidyverse:4.3",
	// Docker container name = same as UI (avoids random names like "wizardly_driscoll"). Image will still show long "vsc-...-features" in Docker Images when using features—that is expected and not configurable.
	"runArgs": ["--name", "${localWorkspaceFolderBasename}"],

	"features": {
		"ghcr.io/rocker-org/devcontainer-features/quarto-cli:1.1.2": {},
		// ADDED: Lightweight virtual desktop for GUI apps like Chrome
		"ghcr.io/devcontainers/features/desktop-lite:1": {
			"webPort": "6080",
			"vncPort": "5901"
		}
		// currently have some issues to install r-packages. (31/10/2023)
		//"ghcr.io/rocker-org/devcontainer-features/r-packages:1.0.3": {
		//    "packages": "plotly,here,readxl,networkD3,leaflet,sf,spData,reactable"
		//}	
	},

	// ADDED: Forward the web port so you can view the desktop from your host browser
	"forwardPorts": [6080, 5901],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "bash install-dev-tools.sh",

	// Configure tool-specific properties.
	"customizations": {
		// Configure properties specific to VS Code/Cursor.
		"vscode": {
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": ["ms-python.python", "ms-toolsai.jupyter"]
		}
	},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// should not use root, but for late: https://stackoverflow.com/questions/64191385/i-get-an-error-when-trying-to-run-as-a-remote-user-for-vs-code-development-conta
	"remoteUser": "root"
}